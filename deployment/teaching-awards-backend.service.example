[Unit]
Description=Teaching Awards Flask Backend
After=network.target mysql.service

[Service]
Type=simple
WorkingDirectory=/opt/teaching-awards-platform/backend
EnvironmentFile=/etc/teaching-awards.env
ExecStart=/opt/teaching-awards-platform/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
